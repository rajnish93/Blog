{
  "version": "0.1.0",
  "private": true,
  "name": "blog-by-rajnish-singh",
  "description": "A minimal, lightweight and mobile-first starter for creating blazing-fast static blogs",
  "license": "0BSD",
  "scripts": {
    "develop": "yarn run clean && gatsby develop",
    "build": "yarn run clean && gatsby build",
    "clean": "rimraf .cache public",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.{js,ts,tsx}\" --fix"
  },
  "author": "Rajnish Singh",
  "dependencies": {
    "gatsby": "^4.4.0",
    "gatsby-plugin-netlify-cms": "^6.4.0",
    "i": "^0.3.7",
    "netlify-cms-app": "^2.15.63",
    "npm": "^8.3.0",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "styled-components": "^5.3.3"
  },
  "devDependencies": {
    "@types/react-helmet": "^6.1.5",
    "@types/styled-components": "^5.1.19",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.5.1",
    "rimraf": "^3.0.2",
    "typescript": "^4.5.4"
  }
}
